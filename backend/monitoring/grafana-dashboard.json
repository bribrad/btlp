      "title": "Request Latency (p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"btlp-backend\"}[1m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}",
          "refId": "A"
